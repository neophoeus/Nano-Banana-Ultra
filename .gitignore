# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Generated dependencies and runtime/build artifacts
node_modules/
dist/
dist-ssr/
output/
test-results/
playwright-report/
coverage/

# Local-only development assets excluded from the tracked repo surface
.prettierignore
prettier.config.mjs

# Local-only scratch test assets
tests-local/
e2e-local/
playwright.local.config.ts

# Local secrets and generated internal reports
.env*.local
e2e-global-log-focus.txt

# Track repo-owned VS Code project metadata, ignore everything else in .vscode/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/extensions.json
!.vscode/launch.json

# Editor directories and files
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
